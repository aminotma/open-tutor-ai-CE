{
    "include": [
        "backend"
    ],
    "exclude": [
        "node_modules",
        "static",
        "cypress",
        "docs",
        "kubernetes",
        "scripts",
        "**/__pycache__",
        "**/*.pyc",
        "**/.*",
        "**/.git",
        "**/.vscode",
        "**/build",
        "**/dist"
    ],
    "pythonVersion": "3.11",
    "pythonPlatform": "Linux",
    "typeCheckingMode": "basic",
    "useLibraryCodeForTypes": true,
    "reportMissingImports": "error",
    "reportMissingTypeStubs": "warning",
    "stubPath": "./backend"
}